{
  "name": "xinliu-desktop",
  "productName": "心流",
  "private": true,
  "version": "0.0.0",
  "description": "心流（Xinliu）Windows 桌面端",
  "main": "dist/main/main.js",
  "scripts": {
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build"
  },
  "build": {
    "appId": "cc.pscly.xinliu.desktop"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.1.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
