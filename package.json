{
  "name": "xinliu-desktop",
  "productName": "心流",
  "private": true,
  "version": "0.0.0",
  "description": "心流（Xinliu）Windows 桌面端",
  "engines": {
    "node": ">=20.0.0 <21"
  },
  "main": "dist/main/main.js",
  "scripts": {
    "lint": "eslint src vite.config.ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "build": "npm run build:electron && npm run build:renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "dist:win": "npm run build && electron-builder --win --x64 --publish never",
    "test:e2e": "electron-builder install-app-deps && playwright test"
  },
  "build": {
    "appId": "cc.pscly.xinliu.desktop",
    "directories": {
      "output": "release"
    },
    "artifactName": "xinliu-desktop-${version}-setup-${arch}.${ext}",
    "asarUnpack": [
      "**/*.node"
    ],
    "executableName": "xinliu-desktop",
    "publish": [
      {
        "provider": "github",
        "owner": "pscly",
        "repo": "xinliu_desktop"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/tray.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "心流"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.30",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^30.1.2",
    "electron-builder": "25.1.8",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "electron-updater": "^6.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
